# Git worktrees (created at repo root by git worktree add)
.worktrees/

# Claude Code per-user / local state. `.claude/` at repo root is a
# transient nested-worktree scratch area; `macos-dev/.claude/` holds
# per-user permission and output-style overrides that belong to the
# individual checkout, not the project. Convention (Claude Code):
# `settings.local.json` is user-local; `settings.json` is shareable
# and would be committed separately if ever needed.
.claude/
macos-dev/.claude/

# Session-continuation scratch pads and superseded draft plans.
# Committed plans live under docs/superpowers/plans/; anything under
# macos-dev/docs/plans/continuation-*.md is per-session context for
# resuming work and should not be version-controlled. The kitty plan
# shipped via origin/plan4-kitty long ago and was superseded by the
# Layer 1b-ii Dracula Pro refresh — the markdown is a stale draft.
macos-dev/docs/plans/continuation-*.md
macos-dev/docs/plans/2026-04-07-04-kitty.md
