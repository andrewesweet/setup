{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4-6",
  "small_model": "github-copilot/gpt-4o-mini",
  "instructions": [
    "~/.config/opencode/instructions/git-conventions.md",
    "~/.config/opencode/instructions/scratch-dirs.md"
  ],
  "permission": {
    "*": "ask",
    "read": {
      "*": "ask",
      "~/workspace/**": "allow",
      "/home/dev/workspace/**": "allow",
      "/tmp/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.config/mise/**": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "bash": {
      "*": "ask",

      // ── Git: read-only verbs ──────────────────────────────────────────────
      "git status": "allow", "git status *": "allow",
      "git diff": "allow", "git diff *": "allow",
      "git log": "allow", "git log *": "allow",
      "git show *": "allow",
      "git branch": "allow", "git branch *": "allow",
      "git stash list": "allow",
      "git blame *": "allow",
      "git reflog": "allow", "git reflog *": "allow",
      "git remote": "allow", "git remote -v": "allow", "git remote show *": "allow",
      "git config --get *": "allow", "git config --list": "allow", "git config -l": "allow",
      "git tag": "allow", "git tag -l *": "allow", "git tag --list *": "allow",
      "git describe": "allow", "git describe *": "allow",
      "git rev-parse *": "allow",
      "git ls-files": "allow", "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git for-each-ref": "allow", "git for-each-ref *": "allow",
      "git shortlog *": "allow",
      "git cat-file -p *": "allow", "git cat-file -t *": "allow",
      "git grep *": "allow",
      "git worktree list": "allow",
      "git whatchanged *": "allow",
      "git name-rev *": "allow",
      "git merge-base *": "allow",
      "git count-objects -v": "allow",

      // ── GitHub CLI: safe read verbs (enumerated from gh 2.89.0) ──────────
      // Derived from docs/research/gh-cli-command-matrix.md — 63 SAFE leaves
      // out of 183 total, classified via scripts/gh-allowlist-audit.sh walker
      // plus per-family source cross-check against github.com/cli/cli.
      // Ordering (last-match-wins): per-family allows → global flag demotions
      // (--web/--edit/--output/--dir/--clobber/--watch/--follow) → credential
      // overrides → gh api block (GET-only, unchanged) → extension explicit
      // denies (placed at the absolute end of bash block).

      // auth / config / status / cache / completion / licenses
      "gh auth status": "allow", "gh auth status *": "allow",
      "gh config get": "allow", "gh config get *": "allow",
      "gh config list": "allow", "gh config list *": "allow",
      "gh config ls": "allow", "gh config ls *": "allow",
      "gh status": "allow", "gh status *": "allow",
      "gh cache list": "allow", "gh cache list *": "allow",
      "gh cache ls": "allow", "gh cache ls *": "allow",
      "gh completion": "allow", "gh completion *": "allow",
      "gh licenses": "allow", "gh licenses *": "allow",

      // repo (list/view + autolink/deploy-key/gitignore/license sub-families)
      "gh repo list": "allow", "gh repo list *": "allow",
      "gh repo view": "allow", "gh repo view *": "allow",
      "gh repo autolink list": "allow", "gh repo autolink list *": "allow",
      "gh repo autolink view": "allow", "gh repo autolink view *": "allow",
      "gh repo deploy-key list": "allow", "gh repo deploy-key list *": "allow",
      "gh repo gitignore list": "allow", "gh repo gitignore list *": "allow",
      "gh repo gitignore view": "allow", "gh repo gitignore view *": "allow",
      "gh repo license list": "allow", "gh repo license list *": "allow",
      "gh repo license view": "allow", "gh repo license view *": "allow",

      // pr (read verbs; create/edit/merge/etc. MUTATING → fall through to ask)
      "gh pr list": "allow", "gh pr list *": "allow",
      "gh pr view": "allow", "gh pr view *": "allow",
      "gh pr diff": "allow", "gh pr diff *": "allow",
      "gh pr checks": "allow", "gh pr checks *": "allow",
      "gh pr status": "allow", "gh pr status *": "allow",

      // issue (read verbs)
      "gh issue list": "allow", "gh issue list *": "allow",
      "gh issue view": "allow", "gh issue view *": "allow",
      "gh issue status": "allow", "gh issue status *": "allow",

      // workflow / run / release / label / project (read verbs)
      "gh workflow list": "allow", "gh workflow list *": "allow",
      "gh workflow view": "allow", "gh workflow view *": "allow",
      "gh run list": "allow", "gh run list *": "allow",
      "gh run view": "allow", "gh run view *": "allow",
      "gh release list": "allow", "gh release list *": "allow",
      "gh release view": "allow", "gh release view *": "allow",
      "gh release verify": "allow", "gh release verify *": "allow",
      "gh release verify-asset": "allow", "gh release verify-asset *": "allow",
      "gh label list": "allow", "gh label list *": "allow",
      "gh project list": "allow", "gh project list *": "allow",
      "gh project view": "allow", "gh project view *": "allow",
      "gh project field-list": "allow", "gh project field-list *": "allow",
      "gh project item-list": "allow", "gh project item-list *": "allow",

      // gist / search / codespace / agent-task (read verbs only)
      "gh gist list": "allow", "gh gist list *": "allow",
      "gh gist view": "allow", "gh gist view *": "allow",
      "gh search repos": "allow", "gh search repos *": "allow",
      "gh search issues": "allow", "gh search issues *": "allow",
      "gh search prs": "allow", "gh search prs *": "allow",
      "gh search code": "allow", "gh search code *": "allow",
      "gh search commits": "allow", "gh search commits *": "allow",
      "gh codespace list": "allow", "gh codespace list *": "allow",
      "gh codespace view": "allow", "gh codespace view *": "allow",
      "gh agent-task list": "allow", "gh agent-task list *": "allow",
      "gh agent-task view": "allow", "gh agent-task view *": "allow",

      // secret / variable / ruleset / alias / extension / attestation /
      // gpg-key / ssh-key / org — list-style reads only
      "gh secret list": "allow", "gh secret list *": "allow",
      "gh variable list": "allow", "gh variable list *": "allow",
      "gh variable get": "allow", "gh variable get *": "allow",
      "gh ruleset list": "allow", "gh ruleset list *": "allow",
      "gh ruleset view": "allow", "gh ruleset view *": "allow",
      "gh ruleset check": "allow", "gh ruleset check *": "allow",
      "gh alias list": "allow", "gh alias list *": "allow",
      "gh extension list": "allow", "gh extension list *": "allow",
      "gh extension search": "allow", "gh extension search *": "allow",
      "gh attestation verify": "allow", "gh attestation verify *": "allow",
      "gh attestation trusted-root": "allow", "gh attestation trusted-root *": "allow",
      "gh gpg-key list": "allow", "gh gpg-key list *": "allow",
      "gh ssh-key list": "allow", "gh ssh-key list *": "allow",
      "gh org list": "allow", "gh org list *": "allow",

      // ── gh global flag demotions (after allows, last-match-wins) ─────────
      // Any SAFE verb above that takes one of these flags is re-asked:
      //   --web/-w   → opens browser outside the session
      //   --edit/--editor → opens $EDITOR
      //   --output/--dir/--clobber → writes files to disk
      //   --watch/--follow → hangs the session on a long-running stream
      "gh * --web*": "ask", "gh * -w *": "ask", "gh * -w": "ask",
      "gh * --edit*": "ask",
      "gh * --output*": "ask",
      "gh * --dir *": "ask", "gh * --dir=*": "ask",
      "gh * --clobber*": "ask",
      "gh * --watch*": "ask",
      "gh * --follow*": "ask",

      // ── gh auth status: demote --show-token (leaks credential) ───────────
      "gh auth status --show-token*": "ask",
      "gh auth status -t*": "ask",
      "gh auth status * --show-token*": "ask",
      "gh auth status * -t*": "ask",

      // ── gh api: GET only (implicit + explicit -X GET) ─────────────────────
      // Rule resolution is last-match-wins (not specificity). Ordering below:
      //   1. broad allow, 2. ask overrides for non-GET methods and body flags,
      //   3. re-allow explicit GET forms so they win over the method asks.
      // `-f`/`-F`/`--field`/`--raw-field`/`--input` silently flip the default
      // method from GET to POST, so they MUST ask even without `-X`.
      // A per-endpoint POST allowlist will be added in a follow-up.
      "gh api": "allow", "gh api *": "allow",
      "gh api *-X *": "ask", "gh api *--method *": "ask",
      "gh api *-XPOST*": "ask", "gh api *-XPUT*": "ask",
      "gh api *-XDELETE*": "ask", "gh api *-XPATCH*": "ask",
      "gh api *-f *": "ask", "gh api *--field*": "ask",
      "gh api *-F *": "ask", "gh api *--raw-field*": "ask",
      "gh api *--input*": "ask",
      "gh api -X GET*": "allow", "gh api --method GET*": "allow",
      "gh api *-XGET*": "allow",

      // ── gh api: narrow POST allow for Copilot review request ─────────────
      // Endpoint (requested_reviewers on any org/repo/PR) and payload (the
      // Copilot reviewer slug) are pinned. `-X*POST` covers both `-X POST`
      // and `-XPOST`; both quoted and unquoted `-f` argument forms are
      // covered. No trailing wildcard: extra flags (`-F`, `--input`, `--jq`,
      // additional `-f reviewers[]=...`) fall through to the general POST
      // ask, preventing exfil-via-body-flag or reviewer piggyback. Blast
      // radius is limited to pinging Copilot to review the PR — no code
      // mutation.
      "gh api repos/*/*/pulls/*/requested_reviewers -X*POST -f reviewers[]=copilot-pull-request-reviewer[bot]": "allow",
      "gh api repos/*/*/pulls/*/requested_reviewers -X*POST -f 'reviewers[]=copilot-pull-request-reviewer[bot]'": "allow",

      // ── curl: GET only (implicit + explicit -X GET) ───────────────────────
      // Same last-match-wins pattern as gh api above. Body flags (`-d`, `-F`,
      // `-T` and their long forms) silently flip curl's default method away
      // from GET, so they MUST ask even without `-X`. Both space (`-X POST`)
      // and no-space (`-XPOST`) method forms are covered.
      // A per-endpoint POST allowlist will be added in a follow-up.
      "curl": "allow", "curl *": "allow",
      "curl *-X *": "ask", "curl *--request *": "ask",
      "curl *-XPOST*": "ask", "curl *-XPUT*": "ask",
      "curl *-XDELETE*": "ask", "curl *-XPATCH*": "ask",
      "curl *-d *": "ask", "curl *--data*": "ask",
      "curl *-F *": "ask", "curl *--form*": "ask",
      "curl *-T *": "ask", "curl *--upload-file*": "ask",
      "curl -X GET*": "allow", "curl --request GET*": "allow",
      "curl *-XGET*": "allow",

      // ── Filesystem inspection (stdlib) ────────────────────────────────────
      "ls": "allow", "ls *": "allow",
      "pwd": "allow",
      "which *": "allow", "type *": "allow", "command -v *": "allow",
      "whereis *": "allow", "apropos *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "readlink *": "allow", "realpath *": "allow",
      "basename *": "allow", "dirname *": "allow",
      "wc": "allow", "wc *": "allow",
      "head *": "allow", "tail *": "allow",
      // tail follow modes hang sessions — placed AFTER `tail *: allow` so
      // findLast returns the ask rule for `tail -f`/`tail -F`.
      "tail -f *": "ask", "tail -F *": "ask",
      "du -sh *": "allow", "du -h *": "allow",
      "df": "allow", "df -h": "allow",
      "tree": "allow", "tree *": "allow",
      "eza": "allow", "eza *": "allow",

      // ── Text inspection / hashing / diff ──────────────────────────────────
      "diff *": "allow",
      "cmp *": "allow",
      "md5sum *": "allow", "sha1sum *": "allow",
      "sha256sum *": "allow", "sha512sum *": "allow",
      "shasum *": "allow",
      "hexdump *": "allow", "xxd *": "allow", "od *": "allow", "strings *": "allow",

      // ── Pure text-transform pipes (no in-place writes) ────────────────────
      // Intentionally excluded: sed, awk, tee, perl, python, ruby, node, bash
      // — all can write to disk via flags/-e/stdin and glob matching can't
      // reliably prevent it.
      "sort": "allow", "sort *": "allow",
      "uniq": "allow", "uniq *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "tac *": "allow", "rev *": "allow", "nl *": "allow",
      "column *": "allow",
      "paste *": "allow", "join *": "allow", "comm *": "allow",
      "fold *": "allow", "fmt *": "allow",
      "expand *": "allow", "unexpand *": "allow",

      // ── Search tools ──────────────────────────────────────────────────────
      "rg *": "allow",
      "fd *": "allow",

      // ── Data wrangling (read-only defaults) ───────────────────────────────
      "jq": "allow", "jq *": "allow",
      "yq": "allow", "yq *": "allow",
      "mlr *": "allow", "miller *": "allow",

      // ── Viewers scoped to workspace/tmp ───────────────────────────────────
      "bat ~/workspace/*": "allow", "bat ~/workspace/**": "allow",
      "bat /home/dev/workspace/*": "allow", "bat /home/dev/workspace/**": "allow",
      "bat /tmp/*": "allow", "bat /tmp/**": "allow",
      "cat ~/workspace/*": "allow", "cat ~/workspace/**": "allow",
      "cat /home/dev/workspace/*": "allow", "cat /home/dev/workspace/**": "allow",
      "cat /tmp/*": "allow", "cat /tmp/**": "allow",
      "glow ~/workspace/*": "allow", "glow /home/dev/workspace/*": "allow",
      "glow /tmp/*": "allow",
      "delta ~/workspace/*": "allow", "delta /home/dev/workspace/*": "allow",
      "delta /tmp/*": "allow",
      "difft *": "allow",

      // ── Environment / system info ─────────────────────────────────────────
      "env": "allow",
      "printenv": "allow", "printenv *": "allow",
      "uname": "allow", "uname *": "allow",
      "hostname": "allow", "whoami": "allow", "id": "allow", "groups": "allow",
      "uptime": "allow", "locale": "allow",
      "date": "allow", "date *": "allow",

      // ── Version / help probes (broad, per-tool) ───────────────────────────
      "* --version": "allow",
      "* -V": "allow",
      "* --help": "allow",
      "* -h": "allow",

      // ── Package / runtime inventory (list-only) ───────────────────────────
      "brew list": "allow", "brew list *": "allow",
      "brew info *": "allow", "brew outdated": "allow", "brew doctor": "allow",
      "npm list": "allow", "npm list *": "allow", "npm ls *": "allow",
      "pnpm list *": "allow", "yarn list *": "allow",
      "bun pm ls": "allow",
      "pip list": "allow", "pip show *": "allow", "pip freeze": "allow",
      "uv pip list": "allow", "uv tree": "allow",
      "cargo tree": "allow", "cargo metadata *": "allow",
      "go list *": "allow", "go env": "allow", "go env *": "allow", "go version": "allow",
      "bundle list": "allow", "gem list": "allow",
      "dpkg -l": "allow", "apt list --installed": "allow",
      "mise list": "allow", "mise ls": "allow", "mise current": "allow",
      "mise env": "allow", "mise doctor": "allow", "mise which *": "allow",

      // ── Linters / analyzers (non-mutating invocations only) ───────────────
      "shellcheck *": "allow",
      "shfmt -d *": "allow", "shfmt -l *": "allow",
      "actionlint": "allow", "actionlint *": "allow",
      "zizmor *": "allow",
      "pinact run --check *": "allow",
      "markdownlint-cli2 *.md": "allow",
      "tflint": "allow", "tflint *": "allow",
      "golangci-lint run": "allow", "golangci-lint run *": "allow",
      "golangci-lint config *": "allow",
      "gofmt -l *": "allow", "gofmt -d *": "allow",
      "goimports -l *": "allow", "goimports -d *": "allow",

      // ── Containers: read verbs ────────────────────────────────────────────
      "podman ps": "allow", "podman ps *": "allow",
      "podman images": "allow", "podman images *": "allow",
      "podman inspect *": "allow", "podman logs *": "allow",
      "podman version": "allow", "podman info": "allow",
      "docker ps": "allow", "docker ps *": "allow",
      "docker images": "allow", "docker inspect *": "allow",
      "docker logs *": "allow",
      "docker version": "allow", "docker info": "allow",

      // ── Kubernetes: read verbs ────────────────────────────────────────────
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl logs *": "allow",
      "kubectl config view": "allow",
      "kubectl config get-contexts": "allow",
      "kubectl config current-context": "allow",
      "kubectl version *": "allow",
      "kubectl api-resources": "allow", "kubectl api-versions": "allow",
      "kubectl cluster-info": "allow",
      "kubectl explain *": "allow",
      "kubectx": "allow", "kubens": "allow",

      // ── gcloud: safe verbs + singleton utilities (enumerated from SDK 564.0.0)
      // Policy rubric:
      //   allow — admin/metadata read AND data read (including `storage ls|cat|
      //           du|hash`, `logging read`, `pubsub pull`, prediction calls,
      //           log reads, serial-port-output reads, `asset query`, etc.)
      //   ask   — admin/metadata write, data write, interactive/session-
      //           blocking, and (MUST) anything that retrieves tokens,
      //           credentials, or wrapped-secret material
      //   ask   — `gcloud alpha *` and `gcloud beta *` (blanket)
      // Classification catalogued in docs/research/gcloud-cli-policy.md,
      // derived from docs/research/gcloud-cli-commands.json + two audits:
      // gcloud-audit-data-plane.md + gcloud-audit-interactive-credential-installs.md.
      //
      // Ordering (last-match-wins):
      //   1. Universal safe-verb allows — one pattern per SAFE verb, covering
      //      every service/resource depth via `*` greedy-across-whitespace.
      //   2. Singleton utility allows (info, version, help, topic, auth list,
      //      config list/configurations list|describe).
      //   3. Data-read allows for verbs not in the universal SAFE set:
      //      `storage ls|cat|du|hash`, `logging read`, `pubsub pull` + message
      //      tests, `kms encrypt|*-verify`, prediction and ml content APIs,
      //      `vector-search * query|batch-search|aggregate`, consent-store
      //      reads, logs reads, compute serial/screenshot/route-policy reads,
      //      asset/policy-intelligence queries, metastore query-metadata,
      //      netapp encrypt/verify.
      //   4. Data-write asks — overrides tier 1–3 where a read-ish verb would
      //      otherwise allow a write (storage cp/mv/rm/rsync/objects create/
      //      batch-operations, pubsub publish/ack, pubsub pull --auto-ack,
      //      logging write/copy, DB export/import/execute-sql/rows, ai-
      //      platform batch prediction, vector-search writes, healthcare
      //      export/import/deidentify, functions call, compute image/diagnose
      //      writes + router upload, composer/transfer/backup/redis/looker/
      //      memorystore/lustre/metastore/scc/infra-manager/artifacts writes).
      //   5. Interactive / session-blocking asks (ssh, scp, tunnel, wait,
      //      tail, stream-*, init, emulators start, feedback, survey, docker).
      //   6. Credential / token retrieval asks (MUST ASK): auth login/print/
      //      revoke, every `* get-credentials*`, SA keys create/upload/sign,
      //      sign-url, kms decrypt/sign/decapsulate, secrets versions access,
      //      redis get-auth-string, sql generate-login-token, developer-
      //      connect fetch tokens, iap reset-secret, api-keys get-key-string,
      //      + defensive wildcards for `* fetch-*-token`, `* generate-login-
      //      token`, `* get-auth-string`, `* get-key-string`.
      //   7. Components asks (install/update/remove/reinstall/repositories).
      //   8. Artifacts print-settings demotion (--json-key can embed SA key).
      //   9. Alpha/beta blanket ask — MUST BE LAST in the gcloud section.

      // Tier 1: universal safe-verb allows
      "gcloud * list": "allow", "gcloud * list *": "allow",
      "gcloud * describe": "allow", "gcloud * describe *": "allow",
      "gcloud * get-iam-policy": "allow", "gcloud * get-iam-policy *": "allow",
      "gcloud * get-ancestors-iam-policy": "allow", "gcloud * get-ancestors-iam-policy *": "allow",
      "gcloud * test-iam-permissions": "allow", "gcloud * test-iam-permissions *": "allow",
      "gcloud * get-value": "allow", "gcloud * get-value *": "allow",
      "gcloud * get-public-key": "allow", "gcloud * get-public-key *": "allow",
      "gcloud * search": "allow", "gcloud * search *": "allow",
      "gcloud * lookup": "allow", "gcloud * lookup *": "allow",
      "gcloud * explain": "allow", "gcloud * explain *": "allow",
      "gcloud * print-settings": "allow", "gcloud * print-settings *": "allow",

      // Tier 2: singleton utilities
      "gcloud info": "allow", "gcloud info *": "allow",
      "gcloud version": "allow", "gcloud --version": "allow",
      "gcloud help": "allow", "gcloud help *": "allow",
      "gcloud topic": "allow", "gcloud topic *": "allow",
      "gcloud cheat-sheet": "allow",
      "gcloud auth list": "allow", "gcloud auth list *": "allow",
      "gcloud config list": "allow", "gcloud config list *": "allow",
      "gcloud config configurations list": "allow", "gcloud config configurations list *": "allow",
      "gcloud config configurations describe": "allow", "gcloud config configurations describe *": "allow",

      // Tier 3: data-read allows (verbs not in the universal SAFE set).
      // Rubric: data-read is eligible for allow. Commands below read user
      // data or model output without writing, without retrieving credentials,
      // and without blocking the session.
      // storage — inspection verbs that print to stdout
      "gcloud storage ls*": "allow",
      "gcloud storage cat*": "allow",
      "gcloud storage du*": "allow",
      "gcloud storage hash*": "allow",
      // logging — entry reads (tail is interactive, write/copy are data-write)
      "gcloud logging read*": "allow",
      // pubsub — message pulls and read-only message tests
      "gcloud pubsub subscriptions pull*": "allow",
      "gcloud pubsub message-transforms test*": "allow",
      "gcloud pubsub schemas validate-message*": "allow",
      // kms — encrypt/verify are data transforms that don't retrieve credentials.
      // decrypt/sign remain ask because decrypted plaintext is typically a
      // wrapped credential and signatures ARE credentials — see tier 6.
      "gcloud kms encrypt*": "allow",
      "gcloud kms raw-encrypt*": "allow",
      "gcloud kms asymmetric-encrypt*": "allow",
      "gcloud kms asymmetric-verify*": "allow",
      "gcloud kms mac-verify*": "allow",
      // ai / ml / model-armor — model invocation with user payload returning
      // prediction. Treated as data-read (no state change, no credential
      // retrieval). Streaming predict is in tier 5 (interactive).
      "gcloud ai endpoints predict*": "allow",
      "gcloud ai endpoints raw-predict*": "allow",
      "gcloud ai endpoints direct-predict*": "allow",
      "gcloud ai endpoints direct-raw-predict*": "allow",
      "gcloud ai endpoints explain*": "allow",
      "gcloud ai-platform predict*": "allow",
      "gcloud ai-platform local predict*": "allow",
      "gcloud ml * *": "allow",
      "gcloud model-armor templates sanitize-*": "allow",
      // vector-search — read verbs not covered by universal (query/batch-search
      // /aggregate). list/describe/search fall through to the universal allows.
      "gcloud vector-search collections data-objects query*": "allow",
      "gcloud vector-search collections data-objects batch-search*": "allow",
      "gcloud vector-search collections data-objects aggregate*": "allow",
      // healthcare — consent-store read queries (PHI access inspection, not
      // export). export/import/deidentify remain ask in tier 4 (data-write).
      "gcloud healthcare consent-stores check-data-access*": "allow",
      "gcloud healthcare consent-stores query-accessible-data*": "allow",
      "gcloud healthcare consent-stores evaluate-user-consents*": "allow",
      // logs reads (tails are interactive, call is arbitrary execution)
      "gcloud functions logs read*": "allow",
      "gcloud app logs read*": "allow",
      "gcloud run services logs read*": "allow",
      "gcloud run jobs logs read*": "allow",
      // compute — VM output reads (tail variants are interactive)
      "gcloud compute instances get-serial-port-output*": "allow",
      "gcloud compute instances get-screenshot*": "allow",
      "gcloud compute routers download-route-policy*": "allow",
      // asset / policy-intelligence / metastore — read queries
      "gcloud asset query*": "allow",
      "gcloud asset get-history*": "allow",
      "gcloud policy-intelligence query-activity*": "allow",
      "gcloud metastore services query-metadata*": "allow",
      // netapp — crypto data transforms (encrypt/verify; no credential leak)
      "gcloud netapp kms-configs encrypt*": "allow",
      "gcloud netapp kms-configs verify*": "allow",

      // Tier 4: data-write asks — override tier 1–3 allows where a read-like
      // verb name would otherwise admit a write.
      // storage — writes to remote or local filesystem
      "gcloud storage cp*": "ask",
      "gcloud storage mv*": "ask",
      "gcloud storage rm*": "ask",
      "gcloud storage rsync*": "ask",
      "gcloud storage restore*": "ask",
      "gcloud storage objects create*": "ask",
      "gcloud storage objects update*": "ask",
      "gcloud storage objects compose*": "ask",
      "gcloud storage objects delete*": "ask",
      "gcloud storage batch-operations *": "ask",
      "gcloud storage managed-folders create*": "ask",
      "gcloud storage managed-folders update*": "ask",
      "gcloud storage managed-folders delete*": "ask",
      "gcloud storage folders create*": "ask",
      "gcloud storage folders delete*": "ask",
      // pubsub — acks are state changes; pull with --auto-ack also mutates.
      "gcloud pubsub subscriptions ack*": "ask",
      "gcloud pubsub topics publish*": "ask",
      "gcloud pubsub lite-topics publish*": "ask",
      "gcloud pubsub lite-subscriptions ack-up-to*": "ask",
      "gcloud pubsub subscriptions pull* --auto-ack*": "ask",
      // logging — data writes
      "gcloud logging write*": "ask",
      "gcloud logging copy*": "ask",
      // kms — signing operations and admin-writes
      "gcloud kms asymmetric-sign*": "ask",
      "gcloud kms mac-sign*": "ask",
      "gcloud kms keys versions import*": "ask",
      // databases — arbitrary SQL executors can mutate; exports/imports are
      // data-writes; spanner rows verbs are explicit writes.
      "gcloud spanner databases execute-sql*": "ask",
      "gcloud spanner databases sessions execute-sql*": "ask",
      "gcloud spanner rows *": "ask",
      "gcloud spanner cli*": "ask",
      "gcloud sql export *": "ask",
      "gcloud sql import *": "ask",
      "gcloud sql instances export*": "ask",
      "gcloud sql instances import*": "ask",
      "gcloud sql instances execute-sql*": "ask",
      "gcloud alloydb clusters export*": "ask",
      "gcloud alloydb clusters import*": "ask",
      "gcloud firestore export*": "ask",
      "gcloud firestore import*": "ask",
      "gcloud firestore bulk-delete*": "ask",
      "gcloud datastore export*": "ask",
      "gcloud datastore import*": "ask",
      "gcloud bigtable backups copy*": "ask",
      "gcloud bigtable instances tables restore*": "ask",
      "gcloud bigtable tables restore*": "ask",
      // ai/ml - arbitrary execution + batch writes
      "gcloud ai-platform jobs submit prediction*": "ask",
      // vector-search — writes/deletes/batch ops
      "gcloud vector-search collections data-objects create*": "ask",
      "gcloud vector-search collections data-objects update*": "ask",
      "gcloud vector-search collections data-objects delete*": "ask",
      "gcloud vector-search collections data-objects batch-create*": "ask",
      "gcloud vector-search collections data-objects batch-update*": "ask",
      "gcloud vector-search collections data-objects batch-delete*": "ask",
      "gcloud vector-search collections export-data-objects*": "ask",
      "gcloud vector-search collections import-data-objects*": "ask",
      // healthcare — PHI writes (export/import/deidentify)
      "gcloud healthcare datasets deidentify*": "ask",
      "gcloud healthcare dicom-stores export *": "ask",
      "gcloud healthcare dicom-stores import *": "ask",
      "gcloud healthcare dicom-stores deidentify*": "ask",
      "gcloud healthcare fhir-stores export *": "ask",
      "gcloud healthcare fhir-stores import *": "ask",
      "gcloud healthcare fhir-stores deidentify*": "ask",
      "gcloud healthcare hl7v2-stores export *": "ask",
      "gcloud healthcare hl7v2-stores import *": "ask",
      // functions - arbitrary user-payload invocation with unknown side effects
      "gcloud functions call*": "ask",
      // compute data-writes (image exports/imports, router uploads, diagnose)
      "gcloud compute images export*": "ask",
      "gcloud compute images import*": "ask",
      "gcloud compute machine-images import*": "ask",
      "gcloud compute instances import*": "ask",
      "gcloud compute instances export*": "ask",
      "gcloud compute diagnose export-logs*": "ask",
      "gcloud compute routers upload-route-policy*": "ask",
      // backup / composer / transfer / memorystore / lustre / metastore / redis / looker
      "gcloud transfer jobs run*": "ask",
      "gcloud transfer jobs create*": "ask",
      "gcloud backup-dr backups restore *": "ask",
      "gcloud composer environments storage *": "ask",
      "gcloud composer environments snapshots load*": "ask",
      "gcloud redis instances export*": "ask",
      "gcloud redis instances import*": "ask",
      "gcloud redis clusters backups export*": "ask",
      "gcloud looker instances export*": "ask",
      "gcloud looker instances import*": "ask",
      "gcloud memorystore backup-collections backups export*": "ask",
      "gcloud lustre instances export-data*": "ask",
      "gcloud lustre instances import-data*": "ask",
      "gcloud metastore services export *": "ask",
      "gcloud metastore services import *": "ask",
      "gcloud netapp volumes restore-backup-files*": "ask",
      // asset / scc / infra-manager — data exports and state file writes
      "gcloud asset export*": "ask",
      "gcloud scc findings export-to-bigquery*": "ask",
      "gcloud infra-manager deployments export-statefile*": "ask",
      "gcloud infra-manager deployments import-statefile*": "ask",
      "gcloud infra-manager deployments export-lock*": "ask",
      "gcloud infra-manager revisions export-statefile*": "ask",
      // artifacts — all downloads/uploads/imports write bytes (local or remote)
      "gcloud artifacts attachments download*": "ask",
      "gcloud artifacts files download*": "ask",
      "gcloud artifacts generic download*": "ask",
      "gcloud artifacts generic upload*": "ask",
      "gcloud artifacts apt upload*": "ask",
      "gcloud artifacts apt import*": "ask",
      "gcloud artifacts yum upload*": "ask",
      "gcloud artifacts yum import*": "ask",
      "gcloud artifacts go upload*": "ask",
      "gcloud artifacts sbom load*": "ask",
      "gcloud artifacts sbom export*": "ask",
      "gcloud artifacts vulnerabilities load-vex*": "ask",

      // Tier 5: interactive / session-blocking asks
      "gcloud init": "ask", "gcloud init *": "ask",
      "gcloud docker*": "ask",
      "gcloud feedback": "ask", "gcloud feedback *": "ask",
      "gcloud survey": "ask", "gcloud survey *": "ask",
      "gcloud * operations wait*": "ask",
      "gcloud * wait": "ask", "gcloud * wait *": "ask",
      "gcloud * stream-logs*": "ask",
      "gcloud app open-console*": "ask",
      "gcloud app instances ssh*": "ask",
      "gcloud app instances scp*": "ask",
      "gcloud cloud-shell ssh*": "ask",
      "gcloud cloud-shell scp*": "ask",
      "gcloud cloud-shell get-mount-command*": "ask",
      "gcloud compute ssh*": "ask",
      "gcloud compute scp*": "ask",
      "gcloud compute config-ssh*": "ask",
      "gcloud compute copy-files*": "ask",
      "gcloud compute start-iap-tunnel*": "ask",
      "gcloud compute connect-to-serial-port*": "ask",
      "gcloud compute reset-windows-password*": "ask",
      "gcloud compute instances tail-serial-port-output*": "ask",
      "gcloud compute instance-groups managed wait-until*": "ask",
      "gcloud compute tpus * ssh*": "ask",
      "gcloud compute tpus * scp*": "ask",
      "gcloud dataproc batches wait*": "ask",
      "gcloud dataproc jobs wait*": "ask",
      "gcloud emulators * start*": "ask",
      "gcloud workflows executions wait*": "ask",
      "gcloud workflows executions wait-last*": "ask",
      "gcloud workstations ssh*": "ask",
      "gcloud workstations start-tcp-tunnel*": "ask",

      // Tier 6: credential / token retrieval asks (MUST ASK per policy).
      // Every command that returns credential material, mints a token, writes
      // credentials to disk, or decrypts wrapped-secret material MUST be ask.
      // auth — credential mutation and token prints
      "gcloud auth login*": "ask",
      "gcloud auth logout*": "ask",
      "gcloud auth revoke*": "ask",
      "gcloud auth activate-service-account*": "ask",
      "gcloud auth print-access-token*": "ask",
      "gcloud auth print-identity-token*": "ask",
      "gcloud auth application-default *": "ask",
      "gcloud auth configure-docker*": "ask",
      "gcloud auth enterprise-certificate-config *": "ask",
      "gcloud anthos auth login*": "ask",
      "gcloud anthos create-login-config*": "ask",
      // All `get-credentials` variants across GKE / Fleet / Hub / Anthos /
      // Attached / AWS / Azure / bare-metal / edge-cloud — wildcard covers them.
      "gcloud * get-credentials*": "ask",
      // iam service-accounts key material and key-use operations
      "gcloud iam service-accounts keys create*": "ask",
      "gcloud iam service-accounts keys upload*": "ask",
      "gcloud iam service-accounts sign-blob*": "ask",
      "gcloud iam service-accounts sign-jwt*": "ask",
      "gcloud iam workforce-pools create-login-config*": "ask",
      "gcloud iam workforce-pools providers keys create*": "ask",
      "gcloud iam workload-identity-pools providers keys create*": "ask",
      // signed URLs embed credential material
      "gcloud compute sign-url*": "ask",
      "gcloud storage sign-url*": "ask",
      // kms — returns plaintext (typically a wrapped credential) or produces
      // signatures / MACs (which are themselves credentials).
      "gcloud kms decrypt*": "ask",
      "gcloud kms raw-decrypt*": "ask",
      "gcloud kms asymmetric-decrypt*": "ask",
      "gcloud kms decapsulate*": "ask",
      "gcloud kms asymmetric-sign*": "ask",
      "gcloud kms mac-sign*": "ask",
      // secrets, redis AUTH, SQL login token, developer-connect tokens, api keys
      "gcloud secrets versions access*": "ask",
      "gcloud redis instances get-auth-string*": "ask",
      "gcloud sql generate-login-token*": "ask",
      "gcloud developer-connect connections git-repository-links fetch-read-token*": "ask",
      "gcloud developer-connect connections git-repository-links fetch-read-write-token*": "ask",
      "gcloud iap oauth-clients reset-secret*": "ask",
      "gcloud services api-keys get-key-string*": "ask",
      // Defensive wildcards for future-introduced credential verbs that don't
      // happen to match any universal SAFE verb. These never cover a
      // universal-SAFE verb, so they don't over-ask existing metadata reads.
      "gcloud * fetch-read-token*": "ask",
      "gcloud * fetch-read-write-token*": "ask",
      "gcloud * get-auth-string*": "ask",
      "gcloud * generate-login-token*": "ask",
      "gcloud * get-key-string*": "ask",

      // Tier 7: components (installs code)
      "gcloud components install*": "ask",
      "gcloud components update*": "ask",
      "gcloud components remove*": "ask",
      "gcloud components reinstall*": "ask",
      "gcloud components repositories *": "ask",

      // Tier 8: artifacts print-settings demotion
      // `--json-key=<path>` can embed SA key material into the printed snippet,
      // so this service's print-settings must ask even though the universal
      // SAFE verb `print-settings` allows it in tier 1.
      "gcloud artifacts print-settings*": "ask",

      // Tier 9: alpha/beta blanket ask (MUST BE LAST in gcloud section)
      "gcloud alpha": "ask", "gcloud alpha *": "ask",
      "gcloud beta": "ask", "gcloud beta *": "ask",

      // ── Cocogitto / changelog (read-only) ─────────────────────────────────
      "cog verify *": "allow",
      "cog check": "allow",
      "cog log": "allow", "cog log *": "allow",
      "git-cliff --context *": "allow",

      // ── Terraform: plan-style, no apply/destroy ───────────────────────────
      "terraform fmt -check": "allow",
      "terraform validate": "allow",
      "terraform version": "allow",
      "terraform show": "allow", "terraform state list": "allow",
      "tf-summarize *": "allow",
      "tenv list": "allow",

      // ── Archives: list only ───────────────────────────────────────────────
      "tar -tvf *": "allow", "tar --list *": "allow",
      "unzip -l *": "allow", "unzip -v *": "allow",
      "7z l *": "allow", "zipinfo *": "allow",

      // ── History / session / misc (read-only) ──────────────────────────────
      "atuin search *": "allow", "atuin stats *": "allow", "atuin status": "allow",
      "zoxide query *": "allow",
      "ghq list": "allow", "ghq list *": "allow",
      "direnv status": "allow", "direnv version": "allow",
      "starship --print-config": "allow", "starship config": "allow",
      "starship module *": "allow",
      "tmux list-sessions": "allow", "tmux list-windows": "allow",
      "tmux list-panes": "allow",
      "tmux show-options *": "allow", "tmux display-message -p *": "allow",

      // ── Network: passive probing only ─────────────────────────────────────
      // curl/wget/xh/httpie intentionally excluded from broad allow (curl is
      // GET-only above; others fall through to *: ask).
      "dig *": "allow", "host *": "allow", "nslookup *": "allow",
      "ping -c * *": "allow",
      "traceroute *": "allow", "tracepath *": "allow",

      // ── Denies (rule resolution is last-match-wins; denies placed BEFORE
      //    the scoped exception so the narrower allow wins for /tmp/opencode-*)
      "rm -rf *": "deny", "rm -fr *": "deny",
      "sudo *": "deny", "chmod 777 *": "deny",

      // ── Scoped cleanup exception ──────────────────────────────────────────
      // Placed after the `rm -rf *: deny` so findLast returns this allow rule
      // for `rm -rf /tmp/opencode-*` paths only.
      "rm -rf /tmp/opencode-*": "allow",

      // ── gh extension: explicit ask for side-effectful verbs (ABSOLUTE LAST)
      // Placed at the very end so these asks win over every prior rule —
      // including `* --help`, `* --version`, and any gh family allow. Extension
      // install/remove/upgrade/exec/create invoke arbitrary third-party code;
      // they are demoted here so the user can approve individually rather than
      // falling through to the default ask by silence (which could otherwise
      // be shadowed by a broader allow pattern added in the future).
      "gh extension install*": "ask",
      "gh extension remove*": "ask",
      "gh extension upgrade*": "ask",
      "gh extension exec*": "ask",
      "gh extension create*": "ask"
    },
    "edit": {
      "*": "ask",
      "~/workspace/**": "allow",
      "/home/dev/workspace/**": "allow",
      "/tmp/**": "allow"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow"
    },
    "doom_loop": "ask"
  },
  "share": "disabled",
  "autoupdate": false // Pin version for supply-chain security. Update deliberately.
}
