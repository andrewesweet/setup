# ── File viewing ─────────────────────────────────────────────────────────────
brew "bat"
brew "glow"
brew "lnav"

# ── Process monitoring ───────────────────────────────────────────────────────
brew "btop"

# ── Terminal multiplexer ─────────────────────────────────────────────────────
brew "tmux"

# ── Data wrangling ───────────────────────────────────────────────────────────
brew "jq"
brew "yq"
brew "miller"
brew "httpie"

# ── Utilities ────────────────────────────────────────────────────────────────
brew "tree"
