brew "typst"

# ── Version management ───────────────────────────────────────────────────────
brew "mise"

# ── Python ───────────────────────────────────────────────────────────────────
brew "uv"

# ── Go quality ───────────────────────────────────────────────────────────────
brew "golangci-lint"
