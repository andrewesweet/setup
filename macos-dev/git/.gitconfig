# .gitconfig — git configuration
# User identity is in ~/.gitconfig.local (gitignored, per-machine).
# See docs/design/git.md for the specification.

[include]
    path = ~/.gitconfig.local

[core]
    pager        = delta
    excludesFile = ~/.gitignore_global
    autocrlf     = input

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate                     = true    # remaps n/N to jump between hunks; disables less search (/)
    side-by-side                 = true
    line-numbers                 = true
    syntax-theme                 = Dracula Pro
    features                     = decorations
    hyperlinks                   = true
    hyperlinks-file-link-format  = "lazygit-edit://{path}:{line}"

[delta "decorations"]
    file-style                   = bold yellow
    file-decoration-style        = none
    hunk-header-style            = line-number syntax

[diff]
    colorMoved = default
    tool       = difftastic

[difftool]
    prompt = false

[difftool "difftastic"]
    cmd = difft "$LOCAL" "$REMOTE"

[merge]
    conflictstyle = diff3
    tool          = nvimdiff

[mergetool "vscode"]
    cmd = code --wait --merge "$REMOTE" "$LOCAL" "$BASE" "$MERGED"

[mergetool]
    keepBackup = false

[pull]
    rebase = true

[rebase]
    autoStash   = true
    autoSquash  = true

[push]
    default        = current
    autoSetupRemote = true

[fetch]
    prune = true

[branch]
    sort = -committerdate

[log]
    date = relative

[stash]
    showPatch = true

[alias]
    undo    = reset HEAD~1 --mixed
    wip     = !git add -A && git commit -m "WIP"
    unwip   = !git log -1 --format='%s' | grep -q 'WIP' && git reset HEAD~1 || echo 'No WIP commit found — nothing undone'
    aliases = config --get-regexp alias

[ghq]
  root = ~/code

# ── Dracula Pro ui.color blocks (theming spec § 3.3, Accents profile) ──
[color "branch"]
    current  = "#8AFF80" bold   # DRACULA_PRO_GREEN
    local    = "#9580FF"        # DRACULA_PRO_BLUE
    remote   = "#FF80BF"        # DRACULA_PRO_MAGENTA
    upstream = "#80FFEA"        # DRACULA_PRO_CYAN
    plain    = "#F8F8F2"        # DRACULA_PRO_FOREGROUND

[color "diff"]
    old        = "#FF9580"      # DRACULA_PRO_RED
    new        = "#8AFF80"      # DRACULA_PRO_GREEN
    frag       = "#FF80BF"      # DRACULA_PRO_MAGENTA (hunk header)
    meta       = "#9580FF"      # DRACULA_PRO_BLUE    (file/commit meta)
    whitespace = "#FFFF80"      # DRACULA_PRO_YELLOW
    func       = "#80FFEA"      # DRACULA_PRO_CYAN    (function line)
    commit     = "#FFCA80"      # DRACULA_PRO_ORANGE

[color "status"]
    added     = "#8AFF80"       # DRACULA_PRO_GREEN
    changed   = "#FFFF80"       # DRACULA_PRO_YELLOW
    untracked = "#FF9580"       # DRACULA_PRO_RED
    branch    = "#9580FF"       # DRACULA_PRO_BLUE
    nobranch  = "#FF80BF"       # DRACULA_PRO_MAGENTA
    header    = "#7970A9"       # DRACULA_PRO_COMMENT
